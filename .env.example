# Supabase — SundayPlan project (the SSO issuer; tenancy tables public.church /
# public.church_member live there). SundayWelcome owns the dedicated `welcome`
# schema in the SAME project, so newcomer cards are scoped per congregation by
# church_id and reuse the suite-wide membership for who may follow up.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cross-subdomain SSO cookie (production only; leave unset for localhost).
# Lets one Sunday Account login span every *.sundaysuite.app app.
NEXT_PUBLIC_COOKIE_DOMAIN=.sundaysuite.app

# Public base URL — used to build the connect-card QR codes + share links.
NEXT_PUBLIC_BASE_URL=https://welcome.sundaysuite.app
